# ─── Server ──────────────────────────────────────────────────
HTTP_PORT=8080
SWAGGER_ENABLE=true

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── MongoDB ─────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=load_tester

# MongoDB Auth (used by `docker-compose.local.yml`)
MONGO_INITDB_ROOT_USERNAME=mongo-root
MONGO_INITDB_ROOT_PASSWORD=
MONGO_APP_USERNAME=mongo-app
MONGO_APP_PASSWORD=
MONGO_APP_DB=load_tester

# ─── ONDC Context ───────────────────────────────────────────
BAP_ID=load-tester-bap
BAP_URI=
BAP_UNIQUE_KEY_ID=key-1
CORE_VERSION=1.2.0
COUNTRY_CODE=IND
DOMAIN=ONDC:RET11
CITY_CODE=std:080

# ─── ONDC Auth (signing & verification) ─────────────────────
BAP_PRIVATE_KEY=
BAP_PUBLIC_KEY=

# ─── Pipeline ───────────────────────────────────────────────
DEFAULT_RPS=100
DEFAULT_DURATION=60s
PIPELINE_STAGE_GAP_SECONDS=5

# ─── Concurrency ────────────────────────────────────────────
MAX_IN_FLIGHT=256

# ─── Rate Limiting ──────────────────────────────────────────
GLOBAL_RPS_LIMIT=2000
PER_SESSION_RPS_LIMIT=150

# ─── Sessions ───────────────────────────────────────────────
SESSION_TTL_SECONDS=3600

# ─── Run Storage ────────────────────────────────────────────
RUN_STORE_BACKEND=memory
RUN_PAYLOAD_TTL_SECONDS=600

# ─── Run Persistence ────────────────────────────────────────
# RUN_PERSISTENCE controls where raw run payloads are written.
# FS -> filesystem under RUNS_FS_ROOT
# DB -> MongoDB collection (run_payloads)
RUN_PERSISTENCE=FS
RUNS_FS_ROOT=./runs
